# .env.example
# ─────────────────────────────────────────────────────────────
# انسخ هذا الملف إلى ".env" وعدّل القيم
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ⚠ مطلوب — يجب أن يكون طويلاً وعشوائياً (32 حرف على الأقل)
# لتوليد مفتاح: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars

# بيئة التشغيل: development | production
FLASK_ENV=production

# تفعيل وضع Debug (0 = إيقاف، 1 = تفعيل) — يجب أن يبقى 0 في الإنتاج
FLASK_DEBUG=0

# عنوان Redis للـ rate limiter + server-side sessions
REDIS_URL=redis://localhost:6379/0

# كلمات مرور bootstrap عند أول تشغيل فقط (اختياري)
# CYBRAIN_ADMIN_PASSWORD=StrongAdminPassword!
# CYBRAIN_ANALYST_PASSWORD=StrongAnalystPassword!
