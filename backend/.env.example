# .env.example — Copy to .env and fill in your values
# Never commit .env to version control.

# ═══════════════════════════════════════════════════════════════
#  REQUIRED
# ═══════════════════════════════════════════════════════════════

SECRET_KEY=generate-a-64-char-random-hex-string-here
FLASK_ENV=production
FLASK_DEBUG=0

# ── Supabase PostgreSQL (required) ────────────────────────────
# Dashboard → Project Settings → API
# Sign up free: https://supabase.com
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════════
#  FREE KEYS — No credit card, sign up and copy your key
# ═══════════════════════════════════════════════════════════════

# ── VirusTotal — URL/IP reputation check ──────────────────────
# Free: 1000 requests/day
# How to get: https://www.virustotal.com → Sign in → My Account → API Key
VT_API_KEY=

# ── AbuseIPDB — IP abuse score ────────────────────────────────
# Free: 1000 checks/day
# How to get: https://www.abuseipdb.com → Account → API → Create Key
ABUSEIPDB_KEY=

# ── NVD (NIST) — CVE database ────────────────────────────────
# Free: raises rate limit from 5 req/30s to 50 req/30s
# How to get: https://nvd.nist.gov/developers/request-an-api-key (email verification)
NVD_API_KEY=

# ── Google Safe Browsing v4 — used by Chrome/Firefox/Safari ──
# Free: 10 000 req/day
# How to get:
#   1. https://console.cloud.google.com → Create project
#   2. APIs & Services → Enable "Safe Browsing API"
#   3. Credentials → Create API Key
GOOGLE_SAFE_BROWSING_KEY=

# ── URLScan.io — URL/domain sandbox scanner ───────────────────
# Free: 5 000 scans/day (private scans require key)
# How to get: https://urlscan.io → Register → Settings → API Keys
URLSCAN_API_KEY=

# ── ProjectDiscovery Cloud (PDCP) — Nuclei cloud engine ───────
# Free tier available: https://cloud.projectdiscovery.io
# How to get: Dashboard → API Keys → Generate
PDCP_API_KEY=

# ── IPinfo.io — IP context (org, ASN, VPN/Tor flags) ─────────
# Free: 50 000 req/month without key; with token: full privacy data
# How to get: https://ipinfo.io/signup → copy your token
IPINFO_TOKEN=

# ── Snyk — dependency vulnerability scanning ──────────────────
# Free: 200 scans/month (no credit card needed)
# How to get: https://snyk.io → Account Settings → General → Auth Token
SNYK_API_KEY=

# ── GEMINI AI — ARIA chatbot online mode ─────────────────────
# Free: 15 req/min on free tier
# How to get: https://aistudio.google.com/app/apikey → Create API Key
GEMINI_API_KEY=

# ═══════════════════════════════════════════════════════════════
#  FREE — NO KEY NEEDED (used automatically)
# ═══════════════════════════════════════════════════════════════
# The following APIs are called with zero configuration:
#
#  SSL Labs API         https://api.ssllabs.com
#    Full TLS/SSL grade (A+ to F) for HTTPS targets
#
#  Mozilla Observatory  https://http-observatory.security.mozilla.org
#    HTTP security header grading (A+ to F)
#
#  Shodan InternetDB    https://internetdb.shodan.io
#    Free IP intelligence: open ports, known CVEs, tags
#
#  OSV.dev              https://api.osv.dev
#    Google Open Source Vulnerability DB for dependencies
#    (covers PyPI, npm, Maven, Go, Rust, RubyGems, etc.)

# ═══════════════════════════════════════════════════════════════
#  ACTIVE SCANNING TOOLS (install separately)
# ═══════════════════════════════════════════════════════════════

# ── OWASP ZAP — Dynamic Application Security Testing ─────────
# Free: https://www.zaproxy.org/download/
# Run in daemon mode: zap.sh -daemon -port 8080 -config api.key=YOUR_KEY
ZAP_URL=http://127.0.0.1:8080
ZAP_API_KEY=
# ZAP_ENABLED=1

# ── Tools to install (no config needed, just install) ─────────
# Nmap:     https://nmap.org/download.html  (Linux: sudo apt install nmap)
# Bandit:   pip install bandit
# Semgrep:  pip install semgrep
# pip-audit: pip install pip-audit
# npm audit: bundled with Node.js (nodejs.org)

# ═══════════════════════════════════════════════════════════════
#  OPTIONAL
# ═══════════════════════════════════════════════════════════════

# Redis (production rate limiting + sessions)
REDIS_URL=redis://localhost:6379/0

# First-run admin bootstrap (auto-generated if blank)
# CYBRAIN_ADMIN_PASSWORD=ChangeThisImmediately!
# CYBRAIN_ANALYST_PASSWORD=ChangeThisImmediately!
